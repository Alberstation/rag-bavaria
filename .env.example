# =============================================================
# Variables de entorno de OpenWebUI
# Copia este archivo a .env para pruebas locales.
# En Railway, configúralas en: Service -> Variables
# =============================================================

# --- Conexión con OpenAI (obligatorio) ---
OPENAI_API_KEY=sk-tu-clave-aqui
# Cambia esta URL si usas un proveedor compatible con la API de OpenAI
# (Azure OpenAI, Groq, OpenRouter, etc.)
OPENAI_API_BASE_URL=https://api.openai.com/v1

# --- Seguridad (MUY recomendado) ---
# Clave secreta para firmar las sesiones/JWT. Si cambia, todos los
# usuarios deben volver a iniciar sesión. Genera una aleatoria, por ej:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga

# --- Opcionales ---
# Desactiva Ollama porque solo usamos OpenAI.
ENABLE_OLLAMA_API=false
# Pon en false tras crear tu cuenta de admin para cerrar el registro.
ENABLE_SIGNUP=true
# Nombre que aparece en la interfaz.
WEBUI_NAME=RAG Bavaria

# NOTA: No definas PORT manualmente en Railway; lo inyecta la plataforma.
